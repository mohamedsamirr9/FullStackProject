# =========================
# FRONTEND (React / Angular)
# =========================

# Node dependencies
/frontend/node_modules/

# Build output
/frontend/dist/
/frontend/build/

# Environment variables
/frontend/.env

# Logs
/frontend/npm-debug.log*
/frontend/yarn-debug.log*
/frontend/yarn-error.log*

# IDE files
/frontend/.vscode/
/frontend/.idea/

# =========================
# BACKEND (.NET WebAPI)
# =========================

# Build directories
/backend/WebApiProject/WebApiProject/bin/
/backend/WebApiProject/WebApiProject/obj/

# User-specific files
/backend/WebApiProject/WebApiProject/*.user
/backend/WebApiProject/WebApiProject/*.suo

# VS Code / Visual Studio
/backend/WebApiProject/WebApiProject/.vscode/
/backend/WebApiProject/WebApiProject/*.vs/

# Environment variables
/backend/WebApiProject/WebApiProject/appsettings.Development.json

# Logs
/backend/WebApiProject/WebApiProject/*.log

# =========================
# GENERAL
# =========================

# MacOS
.DS_Store

# Logs
*.log

# VSCode workspace settings
.vscode/
